rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    
    match /draws/{drawId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
